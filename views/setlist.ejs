<div class="list-page-header">
  <h1>🔍 Search Results</h1>
  <p>Showing sets matching your filters</p>
</div>

<% if (sets.length === 0) { %>
<div class="empty-state">
  <div class="empty-icon">🔎</div>
  <h3>No Sets Found</h3>
  <p>Try adjusting your search filters.</p>
  <a href="/" class="btn-lego btn-lego-primary btn-lg-action" style="margin-top:1rem;">Back to Search</a>
</div>
<% } else { %>

<div class="result-count"><i class="bi bi-grid-fill"></i><%= sets.length %> set<%= sets.length !== 1 ? 's' : '' %> found</div>

<div class="sets-grid">
  <% for (let set of sets) { %>
  <div class="lego-card">
    <div class="card-img-wrapper">
      <img class="card-img" src="<%= set.Image %>" alt="<%= set.Name %>" loading="lazy"
           onerror="this.src='https://via.placeholder.com/200x150?text=No+Image'">
      <% if (set.Release_Year > 1963) { %>
      <span class="card-badge"><%= set.Release_Year %></span>
      <% } %>
    </div>
    <div class="card-body">
      <div class="card-title">
        <a href="/sets/show/<%= set._id %>"><%= set.Name %></a>
      </div>
      <div class="card-meta">
        <div class="meta-item">
          <span class="meta-label">#</span>
          <span><%= set.Set_Number || 'N/A' %></span>
        </div>
        <div class="meta-item">
          <i class="bi bi-puzzle-fill" style="color:#E3000B;font-size:0.75rem;"></i>
          <span><%= set.Pieces > 0 ? set.Pieces.toLocaleString() + ' pcs' : 'N/A' %></span>
        </div>
        <div class="meta-item">
          <i class="bi bi-tag-fill" style="color:#006DB7;font-size:0.75rem;"></i>
          <span><%= set.Price > 0 ? '$' + set.Price : 'N/A' %></span>
        </div>
      </div>
      <div class="card-actions">
        <a href="/sets/show/<%= set._id %>" class="btn-lego btn-lego-primary" style="font-size:0.78rem;padding:0.38rem 0.9rem;">
          <i class="bi bi-eye-fill"></i> View
        </a>
        <% if (loggedIn) { %>
        <a href="/addSet/<%= set._id %>" class="btn-lego btn-lego-yellow" style="font-size:0.78rem;padding:0.38rem 0.9rem;color:#1A1A1A;">
          <i class="bi bi-heart"></i> Wish
        </a>
        <a href="/addOwnedSet/<%= set._id %>" class="btn-lego btn-lego-blue" style="font-size:0.78rem;padding:0.38rem 0.9rem;">
          <i class="bi bi-trophy"></i> Own
        </a>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>

<% } %>

<div class="cta-row" style="margin-top:2rem;">
  <a href="/" class="btn-lego btn-lego-primary btn-lg-action">
    <i class="bi bi-arrow-left me-1"></i> New Search
  </a>
</div>