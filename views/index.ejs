<!-- HERO -->
<div class="lego-hero">
  <h1>🧱 LEGO Set Finder</h1>
  <p>Discover &amp; collect LEGO sets from 1964 to 2021</p>
</div>

<!-- INFO ALERT -->
<div class="lego-alert">
  <i class="bi bi-stars me-2"></i>
  Browse thousands of LEGO sets. Add them to your <strong>Wishlist</strong> or mark them as <strong>Owned</strong> — just sign in to get started!
</div>

<!-- QUICK SEARCH ROW -->
<div class="glass-panel">
  <div class="section-heading">Quick Search</div>
  <div class="search-grid">

    <div>
      <form method="post" action="/sets/byName">
        <label class="form-label" for="s-name"><i class="bi bi-search me-1"></i>By Name</label>
        <div class="d-flex gap-2">
          <input type="text" class="form-control" id="s-name" name="name" placeholder="e.g. Batman" required>
          <button class="btn-lego btn-lego-primary" type="submit"><i class="bi bi-arrow-right"></i></button>
        </div>
      </form>
    </div>

    <div>
      <form method="post" action="/sets/byTheme">
        <label class="form-label" for="s-theme"><i class="bi bi-tag-fill me-1"></i>By Theme</label>
        <div class="d-flex gap-2">
          <input type="text" class="form-control" id="s-theme" name="theme" placeholder="e.g. Star Wars" required>
          <button class="btn-lego btn-lego-primary" type="submit"><i class="bi bi-arrow-right"></i></button>
        </div>
      </form>
    </div>

    <div>
      <form method="post" action="/sets/byYear">
        <label class="form-label" for="s-year"><i class="bi bi-calendar3 me-1"></i>By Year</label>
        <div class="d-flex gap-2">
          <input type="text" class="form-control" id="s-year" name="year" placeholder="e.g. 2017" required>
          <button class="btn-lego btn-lego-primary" type="submit"><i class="bi bi-arrow-right"></i></button>
        </div>
      </form>
    </div>

    <div>
      <form method="post" action="/sets/bySetNum">
        <label class="form-label" for="s-num"><i class="bi bi-hash me-1"></i>By Set Number</label>
        <div class="d-flex gap-2">
          <input type="text" class="form-control" id="s-num" name="SetNum" placeholder="e.g. 75192" required>
          <button class="btn-lego btn-lego-primary" type="submit"><i class="bi bi-arrow-right"></i></button>
        </div>
      </form>
    </div>

  </div>
</div>

<!-- PRICE FILTER -->
<div class="glass-panel" style="animation-delay:0.1s;">
  <div class="section-heading"><i class="bi bi-currency-dollar"></i>Filter by Price</div>
  <form method="post" action="/sets/byPrice">
    <div class="d-flex flex-wrap gap-3 align-items-end">
      <div style="flex:1;min-width:160px;">
        <label class="form-label" for="minPrice">Min Price ($)</label>
        <input type="number" class="form-control" id="minPrice" name="minPrice" placeholder="0" min="0" required>
      </div>
      <div style="flex:1;min-width:160px;">
        <label class="form-label" for="maxPrice">Max Price ($)</label>
        <input type="number" class="form-control" id="maxPrice" name="maxPrice" placeholder="500" min="0" required>
      </div>
      <div>
        <button class="btn-lego btn-lego-primary" type="submit" style="padding:0.56rem 1.4rem;">
          <i class="bi bi-funnel-fill me-1"></i>Search
        </button>
      </div>
    </div>
  </form>
</div>

<!-- ADVANCED FILTER -->
<div class="glass-panel" style="animation-delay:0.2s;">
  <div class="section-heading"><i class="bi bi-sliders"></i>Advanced Multi-Filter</div>
  <form method="post" action="/sets/byFilters">
    <div class="d-flex flex-wrap gap-3 align-items-end">
      <% 
        const filters = [
          {label:'Filter 1', fname:'filter1', vname:'value1', required: true},
          {label:'Filter 2', fname:'filter2', vname:'value2', required: false},
          {label:'Filter 3', fname:'filter3', vname:'value3', required: false},
        ];
        const filterOpts = [
          {val:'None', txt:'— None —'},
          {val:'Name', txt:'Name'},
          {val:'Tags', txt:'Theme'},
          {val:'Release_Year', txt:'Year'},
          {val:'Price|Min', txt:'Min Price'},
          {val:'Price|Max', txt:'Max Price'},
        ];
      %>
      <% filters.forEach(function(f, i) { %>
      <div style="flex:1;min-width:180px;">
        <label class="form-label"><%= f.label %></label>
        <select class="form-select mb-2" name="<%= f.fname %>" <%= f.required ? 'required' : '' %>>
          <% filterOpts.forEach(function(o) { %>
            <% if (!f.required || o.val !== 'None') { %>
            <option value="<%= o.val %>"><%= o.txt %></option>
            <% } %>
          <% }); %>
        </select>
        <input type="text" class="form-control" name="<%= f.vname %>" placeholder="Value" <%= f.required ? 'required' : '' %>>
      </div>
      <% }); %>
      <div>
        <button class="btn-lego btn-lego-primary btn-lg-action" type="submit">
          <i class="bi bi-search me-1"></i>Search
        </button>
      </div>
    </div>
  </form>
</div>

<hr class="lego-divider">

<!-- CTA BUTTONS -->
<div class="cta-row">
  <a class="btn-lego btn-lego-yellow btn-lg-action" href="/wishlist/show">
    <i class="bi bi-heart-fill"></i> My Wishlist
  </a>
  <a class="btn-lego btn-lego-blue btn-lg-action" href="/ownedlist/show">
    <i class="bi bi-trophy-fill"></i> Sets I Own
  </a>
</div>