<div class="list-page-header">
  <h1>❤️ My Wishlist</h1>
  <p><%= sets.length %> set<%= sets.length !== 1 ? 's' : '' %> saved</p>
</div>

<% if (sets.length === 0) { %>
<div class="empty-state">
  <div class="empty-icon">💛</div>
  <h3>Your Wishlist is Empty</h3>
  <p>Search for LEGO sets and add them to your wishlist!</p>
  <a href="/" class="btn-lego btn-lego-yellow btn-lg-action" style="margin-top:1rem;">Browse Sets</a>
</div>
<% } else { %>
<div class="sets-grid">
  <% for (let set of sets) { %>
  <div class="lego-card">
    <div class="card-img-wrapper">
      <img class="card-img" src="<%= set.Image %>" alt="<%= set.Name %>" loading="lazy"
           onerror="this.src='https://via.placeholder.com/200x150?text=No+Image'">
      <% if (set.Release_Year > 1963) { %><span class="card-badge"><%= set.Release_Year %></span><% } %>
    </div>
    <div class="card-body">
      <div class="card-title">
        <a href="/sets/show/<%= set._id %>"><%= set.Name %></a>
      </div>
      <div class="card-meta">
        <div class="meta-item"><span class="meta-label">#</span><span><%= set.Set_Number || 'N/A' %></span></div>
        <div class="meta-item"><i class="bi bi-puzzle-fill" style="color:#E3000B;font-size:0.75rem;"></i><span><%= set.Pieces > 0 ? set.Pieces.toLocaleString() + ' pcs' : 'N/A' %></span></div>
        <div class="meta-item"><i class="bi bi-tag-fill" style="color:#006DB7;font-size:0.75rem;"></i><span><%= set.Price > 0 ? '$' + set.Price : 'N/A' %></span></div>
      </div>
      <div class="card-actions">
        <a href="/sets/show/<%= set._id %>" class="btn-lego btn-lego-primary" style="font-size:0.78rem;padding:0.38rem 0.9rem;">
          <i class="bi bi-eye-fill"></i> View
        </a>
        <a href="/wishlist/remove/<%= set._id %>" class="btn-lego btn-lego-danger" style="font-size:0.78rem;padding:0.38rem 0.9rem;">
          <i class="bi bi-trash-fill"></i> Remove
        </a>
      </div>
    </div>
  </div>
  <% } %>
</div>
<% } %>

<div class="cta-row" style="margin-top:2rem;">
  <a href="/" class="btn-lego btn-lego-primary btn-lg-action"><i class="bi bi-search me-1"></i>Find More Sets</a>
  <a href="/ownedlist/show" class="btn-lego btn-lego-blue btn-lg-action"><i class="bi bi-trophy-fill me-1"></i>View Owned Sets</a>
</div>