<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>LEGO Set Finder</title>
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Bangers&display=swap" rel="stylesheet">
  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid px-3">
      <a class="navbar-brand" href="/">
        <img src="/images/logo.png" alt="LEGO Logo">
        LEGO Explorer
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
        <i class="bi bi-list" style="color:#fff;font-size:1.4rem;"></i>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/"><i class="bi bi-house-fill me-1"></i>Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about"><i class="bi bi-info-circle-fill me-1"></i>About</a>
          </li>
          <% if (!loggedIn) { %>
          <li class="nav-item">
            <a class="nav-link" href="/login"><i class="bi bi-person-fill me-1"></i>Login / Signup</a>
          </li>
          <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/todo"><i class="bi bi-lightbulb-fill me-1"></i>Ideas</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist/show"><i class="bi bi-heart-fill me-1"></i>Wishlist</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/ownedlist/show"><i class="bi bi-trophy-fill me-1"></i>Owned</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right me-1"></i>Logout (<%= username %>)</a>
          </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="page-wrapper">
    <div class="container" style="max-width:1200px;">
      <%- body %>
    </div>
  </div>

  <!-- Floating LEGO bricks background -->
  <div id="lego-bg-canvas"></div>
  <script>
    (function() {
      const canvas = document.getElementById('lego-bg-canvas');
      const colors = [
        'rgba(227,0,11,0.18)',    // LEGO red
        'rgba(0,109,183,0.16)',   // LEGO blue
        'rgba(255,215,0,0.14)',   // LEGO yellow
        'rgba(255,255,255,0.06)', // white
        'rgba(227,0,11,0.10)',
        'rgba(0,109,183,0.10)',
      ];
      const brickSizes = [
        {w:28, h:14}, {w:42, h:14}, {w:56, h:14},  // 1x1, 1x2, 1x3
        {w:28, h:28}, {w:42, h:28},                 // 2x2, 2x3
      ];

      function makeBrick() {
        const el = document.createElement('div');
        el.className = 'brick';
        const size  = brickSizes[Math.floor(Math.random() * brickSizes.length)];
        const color = colors[Math.floor(Math.random() * colors.length)];
        const left  = Math.random() * 100;
        const dur   = 18 + Math.random() * 28;   // 18–46s
        const delay = Math.random() * -40;        // stagger start times

        el.style.cssText = `
          width:${size.w}px; height:${size.h}px;
          background:${color};
          left:${left}vw;
          border: 1px solid rgba(255,255,255,0.06);
          animation-duration:${dur}s;
          animation-delay:${delay}s;
          box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
        `;
        canvas.appendChild(el);
      }

      // Create 28 bricks
      for (let i = 0; i < 28; i++) makeBrick();
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>